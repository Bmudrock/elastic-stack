server.host: "0.0.0.0"
server.port: {{ kibana_port }}
server.name: "{{ kibana_fqdn }}"

server.publicBaseUrl: "https://{{ kibana_fqdn }}:{{ kibana_port }}"

server.ssl:
  enabled: true
  certificate: {{ elastic_tls_dir }}/cert.pem
  key: {{ elastic_tls_dir }}/key.pem

# All-in-one node: Elasticsearch is on the same host.
elasticsearch.hosts: ["https://localhost:9200"]
elasticsearch.username: "kibana_system"
# Password is injected via keystore — do not set here

elasticsearch.ssl:
  certificateAuthorities: ["{{ elastic_tls_dir }}/ca_chain.pem"]
  verificationMode: certificate

xpack.fleet.enabled: true
xpack.fleet.packages:
  - name: apm
    version: latest
  - name: elastic_agent
    version: latest
  - name: system
    version: latest

logging:
  appenders:
    file:
      type: file
      fileName: /var/log/kibana/kibana.log
      layout:
        type: json
  root:
    appenders: [file]
    level: info
